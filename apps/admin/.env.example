# ─── Supabase (backend / auth / database) ───────────────────────────────────
# The admin app reads/writes the same Supabase project as the platform app.
# Admin access is gated by the `role` column on the `profiles` table
# (must be 'admin' or 'superadmin') — see lib/admin/auth.ts.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key bypasses RLS — required for admin queries across all users.
SUPABASE_SERVICE_ROLE_KEY=
