# ─── Supabase (shared backend — used by contact & bug-report forms) ──────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── App URLs ────────────────────────────────────────────────────────────────
# Public base URL for the marketing site (e.g. https://zequel.xyz)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# URL of the platform app, used by CTA buttons (e.g. https://app.zequel.xyz)
NEXT_PUBLIC_PLATFORM_URL=http://localhost:3001
