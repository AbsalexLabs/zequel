# ─── Supabase (backend / auth / database) ───────────────────────────────────
# Project URL and anon key are safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key bypasses RLS — server-only, never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# ─── AI provider (OpenRouter) ────────────────────────────────────────────────
# Used by the research + study AI features (lib/ai/model-service.ts).
OPENROUTER_API_KEY=

# ─── Transactional email (Resend) ───────────────────────────────────────────
# Used for OTP codes and the account data-export email.
RESEND_API_KEY=

# ─── App URLs ────────────────────────────────────────────────────────────────
# Public base URL of the platform app (e.g. https://app.zequel.xyz).
NEXT_PUBLIC_SITE_URL=http://localhost:3001
