{
  "name": "zequel",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:website": "turbo run dev --filter=@zequel/website",
    "dev:platform": "turbo run dev --filter=@zequel/platform",
    "dev:admin": "turbo run dev --filter=@zequel/admin",
    "build:website": "turbo run build --filter=@zequel/website",
    "build:platform": "turbo run build --filter=@zequel/platform",
    "build:admin": "turbo run build --filter=@zequel/admin",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "5.7.3"
  }
}
